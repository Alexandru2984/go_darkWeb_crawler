DATABASE_URL=postgres://USER:PASSWORD@localhost:5432/onion_spider?sslmode=disable
PORT=8900
TOR_PROXY=127.0.0.1:9050
WORKERS=3
MAX_DEPTH=2

# Secret JWT — obligatoriu. Minim 32 caractere.
# Genereaza cu: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_WITH_openssl_rand_hex_32

# Origini permise pentru CORS (separate cu virgula).
CORS_ORIGIN=https://example.com

# Baza URL folosita in linkul din emailul de verificare (fallback: CORS_ORIGIN[0]).
VERIFY_URL_BASE=https://example.com

# Primul user care se inregistreaza cu acest email devine admin,
# dar DOAR daca nu exista inca niciun admin in DB. Lasa gol pentru a dezactiva.
ADMIN_EMAIL=

# SMTP pentru emailuri de verificare (lasa gol pentru dev — emailurile nu se trimit).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@example.com

# Tor control port (optional, pentru rotatie circuit automata)
TOR_CONTROL_ADDR=127.0.0.1:9051
TOR_CONTROL_PASSWORD=
TOR_CONTROL_COOKIE=/run/tor/control.authcookie
