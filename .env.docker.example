# Copy to .env.docker and edit. Used by `docker compose --env-file .env.docker up`.
# Never commit .env.docker — only this example is tracked.

# --- Postgres (used by both the postgres container and the api DATABASE_URL) ---
POSTGRES_DB=onion_spider
POSTGRES_USER=spider_user
POSTGRES_PASSWORD=change_me_to_something_strong

# --- JWT — REQUIRED, min 32 chars. Generate with: openssl rand -hex 32 ---
JWT_SECRET=replace_me_with_openssl_rand_hex_32_output_at_least_32_chars

# --- Frontend origin (used for CORS and for the verification email link) ---
CORS_ORIGIN=http://localhost:8080
VERIFY_URL_BASE=http://localhost:8080

# --- Bootstrap admin: the FIRST user to register with this email becomes admin,
#     but ONLY if no admin exists yet in the DB. Leave empty to disable. ---
ADMIN_EMAIL=

# --- Public registration. Off by default — flip to "true" to allow signups. ---
ALLOW_REGISTRATION=false

# --- Crawler tuning ---
WORKERS=3
MAX_DEPTH=2
AUDIT_RETENTION_DAYS=90

# --- SMTP (leave SMTP_HOST empty for dev — the api logs the verification link
#     instead of emailing it). For Gmail use app passwords, not your main one. ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
